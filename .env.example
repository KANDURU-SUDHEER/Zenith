# ─── Required API Keys ───────────────────────────────────────────────────────

# NASA API Key (get one free at https://api.nasa.gov/)
# Used for: APOD (Astronomy Picture of the Day)
NASA_API_KEY=your_nasa_api_key_here

# Cesium Ion Access Token (get one free at https://cesium.com/ion/)
# Used for: 3D Globe rendering with Ion imagery
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ─── Optional API Keys ───────────────────────────────────────────────────────

# Google Gemini API Key (get one free at https://aistudio.google.com/apikey)
# Used for: AI Sky Guide chat
# Model: gemini-2.5-flash (free tier: 500 req/day, 1M token context)
# If missing: Falls back to predefined educational responses
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (get one free at https://openweathermap.org/api)
# Used for: Real-time cloud overlay on the 3D globe
# If missing: Cloud overlay is disabled, all other features work normally
NEXT_PUBLIC_OWM_API_KEY=your_owm_api_key_here

# ─── Public APIs (no key required) ──────────────────────────────────────────
# These are used automatically with no configuration needed:
# - WhereTheISS / OpenNotify: ISS real-time position
# - CelesTrak: Satellite TLE orbital data
# - NASA JPL Horizons: Ephemeris / planetary data
# - Nominatim (OpenStreetMap): Geocoding and city search
